ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# 任意。trueにすると、ANTHROPIC_API_KEYが設定されていても
# 常にモックモード（簡易ルール解析）で動作します。
MOCK_MODE=

# Google連携（任意）。設定しない場合、カレンダー登録・スプレッドシート書き出しは無効のままです。
# サービスアカウントのメールアドレス
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# サービスアカウントの秘密鍵（JSONキーの private_key の値をそのまま貼り付ける。改行は \n のままでよい）
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# 車両予約を登録するGoogleカレンダーのカレンダーID（サービスアカウントと共有しておくこと）
GOOGLE_CALENDAR_ID=
# 書き出し先のGoogleスプレッドシートID（URLの /d/ と /edit の間の文字列）
GOOGLE_SHEETS_SPREADSHEET_ID=
